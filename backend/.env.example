# Server
PORT=3001

# Database (PostgreSQL, default port 5432)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=csiallsaints

# Admin API key (use a long random string for GET /api/choir-registrations)
ADMIN_API_KEY=your-secret-admin-key-change-this

# SMTP for confirmation emails (e.g. Gmail, Hostinger email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
