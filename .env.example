# Formspree form ID for the Contact page "Send Us a Message" form.
# 1. Sign up at https://formspree.io and create a new form.
# 2. Set the notification email to your church email (e.g. allsaintscsichurchtcr2020@gmail.com).
# 3. Copy your form ID from the form endpoint (e.g. xpwnqkab from https://formspree.io/f/xpwnqkab).
# 4. Copy this file to .env and set the value:
VITE_FORMSPREE_ID=

# Choir registration API (PHP backend)
# `npm run dev` also loads .env.development (committed) → local PHP by default.
# Local: http://127.0.0.1:8080 — browser calls PHP directly (see api.ts resolveApiBase); avoids Vite multipart proxy 500.
# To hit Hostinger from dev, set in .env.local: VITE_API_URL=https://csiallsaintstcr.com/backend-php
VITE_API_URL=http://127.0.0.1:8080
VITE_API_LOCAL_PROXY_TARGET=http://127.0.0.1:8080
# Optional: Vite dev port (default 5173)
# VITE_DEV_PORT=5173
# Production: https://csiallsaintstcr.com/backend-php (use .env.production for builds)

# Optional: admin API key for the choir registrations dashboard (GET /api/choir-registrations).
# If set, the dashboard can fetch without asking for the key each time.
# If the key contains #, quote the value: VITE_ADMIN_API_KEY="All@Saints#2026"
VITE_ADMIN_API_KEY=

# Staff hub (no password): open #/admin for links to choir list and events admin.
